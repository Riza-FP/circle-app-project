# Required environment variables for production deployment

# The URL of your PostgreSQL database (e.g. from Railway Database, Neon, Supabase)
DATABASE_URL="postgresql://user:password@host:port/database"

# Your JSON Web Token Secret (Make this a long, random string)
JWT_SECRET="your-super-secret-production-key"

# The production URL of your frontend built on Vercel so CORS allows requests
FRONTEND_URL="https://your-frontend.vercel.app"
